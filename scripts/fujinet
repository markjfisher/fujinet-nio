#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_DIR="${ROOT}/build/.venv"
PY_SRC="${ROOT}/py"

# Caller shells often have VIRTUAL_ENV set; ignore it so uv targets this project.
unset VIRTUAL_ENV

# Ensure uv is available
ensure_uv() {
  if ! uv -q --version &> /dev/null; then
    echo "[fujinet] uv is required but not found. Installing..."
    if ! pipx install uv &> /dev/null; then
      echo "[fujinet] ERROR: pipx is required to install uv. Install with: python3 -m pip install --user pipx"
      exit 1
    fi
    export PATH="$HOME/.local/bin:$PATH"
  fi
}

ensure_venv() {
  if [[ ! -x "${VENV_DIR}/bin/python" ]]; then
    echo "[fujinet] creating venv at ${VENV_DIR}"
    mkdir -p "$(dirname "${VENV_DIR}")"
    uv -q venv "${VENV_DIR}"
  fi
}

editable_pth() {
  find "${VENV_DIR}/lib" -name '__editable__.fujinet_tools-*.pth' 2>/dev/null | head -1
}

repair_editable_if_stale() {
  local pth
  pth="$(editable_pth || true)"
  if [[ -z "${pth}" ]]; then
    return
  fi
  if [[ "$(tr -d '\r\n' < "${pth}")" == "${PY_SRC}" ]]; then
    return
  fi
  echo "[fujinet] repairing stale editable install (project moved?)"
  printf '%s\n' "${PY_SRC}" > "${pth}"
}

ensure_synced() {
  # Install into build/.venv (not the default project-root .venv).
  export UV_PROJECT="${ROOT}"
  export UV_PROJECT_ENVIRONMENT="${VENV_DIR}"
  uv -q sync >/dev/null
  repair_editable_if_stale
}

run_cli() {
  # Always expose in-tree sources so CLI works even if editable metadata is stale.
  export PYTHONPATH="${PY_SRC}${PYTHONPATH:+:${PYTHONPATH}}"
  exec "${VENV_DIR}/bin/python" -m fujinet_tools.cli "$@"
}

cd "${ROOT}"
ensure_uv
ensure_venv
ensure_synced
run_cli "$@"
